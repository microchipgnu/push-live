{
  "name": "push-live",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "push-live": "src/cli/push-live.ts"
  },
  "scripts": {
    "dev": "bunx wrangler dev",
    "deploy": "bunx wrangler deploy",
    "db:local": "bunx wrangler d1 migrations apply sloop-db --local",
    "db:remote": "bunx wrangler d1 migrations apply sloop-db --remote",
    "typecheck": "bunx tsc --noEmit",
    "smoke": "bash scripts/smoke.sh",
    "aeo:check": "node scripts/aeo-check.mjs",
    "cli": "bun run src/cli/push-live.ts"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "aws4fetch": "^1.0.20",
    "zod": "^3.23.8",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "bun-types": "^1.3.13",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}
